{
  "kind": "collectionType",
  "collectionName": "book_reviews",
  "info": {
    "singularName": "book-review",
    "pluralName": "book-reviews",
    "displayName": "BookReview"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "rating": {
      "type": "integer",
      "required": true,
      "min": 1,
      "max": 5
    },
    "body": {
      "type": "richtext",
      "required": false
    },
    "author": {
      "type": "string",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "content": {
      "type": "blocks",
      "required": true
    }
  }
}
